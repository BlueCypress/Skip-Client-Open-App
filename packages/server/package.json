{
  "name": "@askskip/server",
  "type": "module",
  "version": "0.0.3",
  "description": "Skip Client Open App server (runtime) package — SkipProxyAgent, SkipSDK, scoped callback-key provisioner, and server middleware. Loads only on MJ instances that install the Skip Client Open App.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "/dist"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch"
  },
  "author": "BlueCypress",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlueCypress/Skip-Client-Open-App"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@askskip/core": "0.0.3",
    "@askskip/types": "0.0.3",
    "@memberjunction/ai": "5.44.0",
    "@memberjunction/ai-agents": "5.44.0",
    "@memberjunction/ai-core-plus": "5.44.0",
    "@memberjunction/aiengine": "5.44.0",
    "@memberjunction/api-keys": "5.44.0",
    "@memberjunction/core": "5.44.0",
    "@memberjunction/core-entities": "5.44.0",
    "@memberjunction/data-context": "5.44.0",
    "@memberjunction/global": "5.44.0",
    "@memberjunction/interactive-component-types": "5.44.0",
    "@memberjunction/server": "5.44.0",
    "@memberjunction/sqlserver-dataprovider": "5.44.0",
    "mssql": "^11.0.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3"
  }
